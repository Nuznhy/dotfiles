#!/usr/bin/env bash

NOTES_DIR="$HOME/notes" 
mkdir -p "$NOTES_DIR" 

RESULT=$(find "$NOTES_DIR" -maxdepth 1 -type f -name "*.md" -printf "%f\n" | 
         fzf --prompt="Note > " \
             --preview="bat --style=plain --color=always $NOTES_DIR/{}" \
             --print-query \
             --header="Enter to open, or type name and Enter to create")

# Read query and selection into variables
QUERY=$(echo "$RESULT" | sed -n '1p')
SELECTED=$(echo "$RESULT" | sed -n '2p')

# Determine which file to open
if [ -n "$SELECTED" ]; then
    FILE="$NOTES_DIR/$SELECTED"
elif [ -n "$QUERY" ]; then
    [[ "$QUERY" != *.md ]] && NAME="$QUERY.md" || NAME="$QUERY"
    FILE="$NOTES_DIR/$NAME"
    
    if [ ! -f "$FILE" ]; then
        echo "# ${QUERY%.md}" > "$FILE"
    fi
else
    exit 0
fi

nvim "$FILE"
